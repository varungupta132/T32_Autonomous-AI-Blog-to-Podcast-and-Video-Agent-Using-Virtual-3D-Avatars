# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Database
DATABASE_URL=sqlite:///./podcasts.db

# Server
BACKEND_PORT=8000

# Storage (optional - defaults will be used if not set)
# OUTPUT_DIR=./outputs
# TEMP_DIR=./temp

# Security (optional - defaults will be used if not set)
# API_RATE_LIMIT=10
# MAX_BLOG_LENGTH=10000
